        given-names: "Jianfang"
    title: "An Integrated TCGA Pan-Cancer Clinical Data Resource to Drive High-Quality Survival Outcome Analytics"
    journal: "Cell"
    volume: 173
    issue: 2
    pages: "400-416.e11"
    year: 2018
    doi: "10.1016/j.cell.2018.02.052"
